        "Amyloid Status & Burden",
        "Tau Burden & Staging Support",
        "FDG Metabolic Pattern Analysis",
        "Structural Atrophy (Thickness/VBM)",
        "Functional Network Assessment",
        "Final Differential Diagnosis Probability",
        "QC Summary"
      ],

      "regulatory_metadata": {
        "intended_use_statement": "Supports differential diagnosis by providing quantitative multimodal markers; not intended as sole diagnostic evidence.",
        "human_in_the_loop": true
      }
    },

