      "report_structure": [
        "Executive Summary",
        "Structural Brain Index",
        "Functional Connectivity Profile",
        "Effective Connectivity Directionality",
        "Network Complexity Index",
        "Personalized Treatment Support",
        "QC Summary"
      ],

      "regulatory_metadata": {
        "intended_use_statement": "Provides quantitative biomarkers to support clinician review; not intended to determine medication choice automatically.",
        "human_in_the_loop": true
      }
    },

    "Dementia_Diagnosis": {
