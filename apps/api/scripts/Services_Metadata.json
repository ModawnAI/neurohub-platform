        "clinical_data_optional": ["Family_history", "Vascular_risk_factors"]
      },

      "qc_policy": {
        "minimum_qc_score": 60,
        "fail_qc_score": 40,
        "actions": {
          "below_minimum": ["Down-weight affected modality", "Flag limited reliability"],
          "below_fail": ["Exclude modality", "Recommend repeat if feasible"]
        }
      },

      "integration_model": {
        "type": "Differential probability scoring",
        "fusion_method": "QC-adjusted multimodal Bayesian scoring",
        "core_outputs": ["ATNProfile", "DifferentialDiagnosisProbabilities", "BrainAgingIndex"],
        "base_weights_default": {
          "Amyloid_PET": 0.20,
          "Tau_PET": 0.20,
