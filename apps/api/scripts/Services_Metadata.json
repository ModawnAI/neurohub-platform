      "target_population": ["Sleep apnea suspicion", "Chronic fatigue", "Daytime sleepiness"],

      "techniques": ["Sleep_Apnea_Analysis", "EEG_Spectrum"],

      "input_requirements": {
        "physiology": {
          "mandatory_all": ["PSG_EEG", "Respiratory_airflow", "Thoracoabdominal_effort", "SpO2"],
          "optional": ["ECG", "EMG", "EOG", "Snore_mic", "Body_position"]
        },
        "clinical_data_minimum": ["Age", "Sex", "BMI", "Sleep_questionnaire_scores"],
        "clinical_data_optional": ["Comorbidities", "Medication_list"]
      },

      "qc_policy": {
        "minimum_qc_score": 60,
        "fail_qc_score": 40,
