{
  "name": "neurohub",
  "private": true,
  "packageManager": "bun@1.2.2",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "web:dev": "bun --cwd apps/web run dev",
    "web:build": "bun --cwd apps/web run build",
    "web:check": "bun --cwd apps/web run check",
    "web:lint": "bun --cwd apps/web run lint"
  }
}
